{
  "name": "gea",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:gea": "npm run build -w @geajs/core",
    "build:gea-mobile": "npm run build -w @geajs/mobile",
    "build:vite-plugin": "npm run build -w @geajs/vite-plugin",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "test": "npm run test --workspaces --if-present",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "format:check": "prettier --check .",
    "docs:dev": "vitepress dev docs",
    "docs:build": "npm run build:docs -w @geajs/ui && vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "typescript-eslint": "^8.57.0",
    "vitepress": "^1.6.4"
  }
}
